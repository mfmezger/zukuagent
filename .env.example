# API Keys
GOOGLE_API_KEY=your_google_api_key_here

# Runtime Settings
DEFAULT_PROVIDER=google
GOOGLE_MODEL=gemini-2.5-flash
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=local
OPENLIT_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OPENLIT_DB_PASSWORD=replace_with_a_strong_password
OPENLIT_DB_USER=default
OPENLIT_DB_NAME=openlit
OPENLIT_IMAGE=ghcr.io/openlit/openlit:1.26.0

# Transcription Settings
TRANSCRIPTION_MODEL=nemo-parakeet-tdt-0.6b-v3

# Heartbeat Settings
HEARTBEAT_INTERVAL_MINUTES=10
HEARTBEAT_FILE=HEARTBEAT.md

# Identity Settings
IDENTITY_DIR=config/identity
IDENTITY_FILES=IDENTITY.md,SOUL.md,AGENTS.md,USER.md

# Endpoint Settings
ENDPOINT_MODE=cli

# Cron Tool Settings
CRON_ENABLED=true
CRON_LOG_DIR=.zukuagent/cron
CRON_AGENT_CLI=zukuagent
CRON_SCRIPT_SANDBOX_MODE=restricted
# Template used when sandbox mode is "monty". Must include {command}.
CRON_MONTY_TEMPLATE=monty sandbox run -- {command}
# Storage Settings
AGENT_STORAGE=local
AGENTFS_ID=zukuagent
AGENTFS_DB_PATH=

# Telegram Settings
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_ALLOWED_PAIRING_DEVICES=
TELEGRAM_REQUIRE_PAIRING=true
TELEGRAM_PAIRINGS_FILE=.telegram_pairings.json
