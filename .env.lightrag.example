# LightRAG server container settings
HOST=0.0.0.0
PORT=9621
WORKING_DIR=/app/data/lightrag

# Set provider binding + model combination for your deployment.
LLM_BINDING=openai
LLM_MODEL=gpt-4o-mini
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=text-embedding-3-small

# Provider credentials (example for OpenAI-compatible setups)
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Optional API auth key if enabled in your LightRAG setup
LIGHTRAG_API_KEY=
